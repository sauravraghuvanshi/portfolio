{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node .github/hooks/session-start.js",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/session-stop.js",
        "timeout": 5
      }
    ]
  }
}
