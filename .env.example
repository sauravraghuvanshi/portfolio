# Site URL (update before deploying)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Analytics (optional — add your own)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# Azure Application Insights (optional — enables telemetry)
# NEXT_PUBLIC_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://xxx.applicationinsights.azure.com/

# Admin Authentication (required for /admin panel)
ADMIN_USERNAME=your-username
ADMIN_PASSWORD=your-strong-password
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Kudu credentials — auto-syncs admin-created content on `npm run dev`
# Get password: az webapp deployment list-publishing-profiles \
#   --name saurav-portfolio --resource-group rg-saurav-portfolio \
#   --query "[?publishMethod=='ZipDeploy']|[0].userPWD" --output tsv
KUDU_USER=$saurav-portfolio
KUDU_PASS=your-kudu-password

# Azure Blob Storage (required for blog image uploads)
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER_NAME=blog-images
NEXT_PUBLIC_AZURE_STORAGE_URL=https://your-account.blob.core.windows.net/blog-images

# Azure OpenAI (required for AI Writer)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Image generation (can use a separate Azure OpenAI resource from the chat model)
# AZURE_OPENAI_IMAGE_ENDPOINT=https://your-image-resource.openai.azure.com
# AZURE_OPENAI_IMAGE_API_KEY=your-image-api-key
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-2-1
# Optional: dedicated Azure AI Foundry agent for AI Writer (uses stronger model)
# AI_WRITER_AGENT_NAME=your-ai-writer-agent-name

# Grounding — Bing Search (optional, enhances AI Writer grounding)
# BING_SEARCH_API_KEY=your-bing-key

# Grounding — Azure AI Search (optional, deeper RAG for AI Writer)
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_API_KEY=your-search-key
# AZURE_SEARCH_INDEX_NAME=microsoft-learn
